rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read-only collections ─────────────────────────────────────
    // Anyone can READ these. Only authenticated admins can WRITE.

    match /services/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /industries/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /caseStudies/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blogs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Contact enquiries ────────────────────────────────────────────────
    // Anyone can CREATE (submit the contact form). Only admins can read.

    match /contactInquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── Job applications ─────────────────────────────────────────────────
    // Anyone can CREATE (submit a form). No one can read from the client.
    // Read them only via Firebase Console or Admin SDK.

    match /jobApplications/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
